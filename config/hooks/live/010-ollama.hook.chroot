#!/bin/bash
# Owned by Person 3.
# Runs inside the chroot during 'lb build' to bake Ollama + TinyLlama
# into the image so it's present at first boot, offline.
#
# Numeric prefix (010-) controls run order relative to other hooks in
# this folder \u2014 lower numbers run first. Keep this early since other
# hooks may depend on system packages already being present.

set -e

curl -fsSL https://ollama.com/install.sh | sh

# Pull the 2GB-tier model at build time so it's baked into the ISO,
# not downloaded on first boot (we're offline-first).
ollama serve &
# Wait for Ollama service to start responding (up to 30 seconds)
for i in {1..30}; do
  if curl -s http://localhost:11434/ >/dev/null; then
    break
  fi
  sleep 1
done
ollama pull tinyllama
kill %1 || true
